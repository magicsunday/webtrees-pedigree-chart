        "d3-hierarchy": "^3.0",
        "d3-path": "^3.0",
        "d3-scale": "^4.0",
        "d3-selection": "^3.0",
        "d3-shape": "^3.0",
        "d3-timer": "^3.0",
        "d3-transition": "^3.0",
        "d3-zoom": "^3.0",
        "eslint": "^10.0",
        "globals": "^17.0",
        "rollup": "^4.0",
        "rollup-plugin-license": "^3.0"
    }
